PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ump_rms_db
DB_USER=ump_rms_user
# Same default as docker-compose POSTGRES_PASSWORD; override locally if yours differs.
DB_PASSWORD=change_me
# Must be non-empty; a blank JWT_SECRET breaks login (jsonwebtoken: secretOrPrivateKey must have a value).
JWT_SECRET=9598910426
# Comma-separated if multiple UIs (e.g. http://localhost:5173,http://rms-fe:5173)
FRONTEND_ORIGIN=http://rms-fe:5173

# Optional: seeded admin (npm run seed). Default username nltanh → login as nltanh@ump.edu.vn
# Run from repo root: npm run seed   — or from backend/: npm run seed
# SEED_ADMIN_USERNAME=nltanh
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_DISPLAY_NAME=Quản trị viên
